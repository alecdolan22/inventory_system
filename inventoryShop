import tkinter as tk
from tkinter import messagebox
import sqlite3

# Initialize database
conn = sqlite3.connect("inventory.db")
cursor = conn.cursor()
cursor.execute('''CREATE TABLE IF NOT EXISTS inventory (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    quantity INTEGER,
    price REAL
)''')
conn.commit()

# Functions
def add_item():
    name = name_entry.get()
    quantity = qty_entry.get()
    price = price_entry.get()
    if name and quantity and price:
        cursor.execute("""INSERT INTO inventory (name, quantity, price)
                          VALUES (?, ?, ?)""", 
                       (name, int(quantity), float(price)))
        conn.commit()
        view_items()
        clear_entries()
    else:
        messagebox.showwarning("Missing Fields", "Please fill all 
fields.")

def update_item():
    try:
        selected = listbox.curselection()[0]
        item = listbox.get(selected)
        item_id = item.split(":")[0]
        cursor.execute("""UPDATE inventory 
                          SET name=?, quantity=?, price=? 
                          WHERE id=?""",
                       (name_entry.get(), int(qty_entry.get()), 
float(price_entry.get()), item_id))
        conn.commit()
        view_items()
        clear_entries()
    except:
        messagebox.showwarning("Select Item", "Select an item to update.")

def delete_item():
    try:
        selected = listbox.curselection()[0]
        item = listbox.get(selected)
        item_id = item.split(":")[0]
        cursor.execute("""DELETE FROM inventory WHERE id=?""", (item_id,))
        conn.commit()
        view_items()
        clear_entries()
    except:
        messagebox.showwarning("Select Item", "Select an item to delete.")

def view_items():
    listbox.delete(0, tk.END)
    cursor.execute("SELECT * FROM inventory")
    for row in cursor.fetchall():
        listbox.insert(tk.END, f"{row[0]}: {row[1]} | Qty: {row[2]} | 
Price: ${row[3]:.2f}")

def on_select(event):
    try:
        selected = listbox.curselection()[0]
        item = listbox.get(selected)
        parts = item.split(" | ")
        id_and_name = parts[0].split(": ")
        qty = parts[1].split(": ")[1]
        price = parts[2].split(": $")[1]

        name_entry.delete(0, tk.END)
        name_entry.insert(tk.END, id_and_name[1])
        qty_entry.delete(0, tk.END)
        qty_entry.insert(tk.END, qty)
        price_entry.delete(0, tk.END)
        price_entry.insert(tk.END, price)
    except IndexError:
        pass

def clear_entries():
    name_entry.delete(0, tk.END)
    qty_entry.delete(0, tk.END)
    price_entry.delete(0, tk.END)

# GUI Layout
root = tk.Tk()
root.title("Inventory Management")

tk.Label(root, text="Item Name:").grid(row=0, column=0)
name_entry = tk.Entry(root)
name_entry.grid(row=0, column=1)

tk.Label(root, text="Quantity:").grid(row=1, column=0)
qty_entry = tk.Entry(root)
qty_entry.grid(row=1, column=1)

tk.Label(root, text="Price:").grid(row=2, column=0)
price_entry = tk.Entry(root)
price_entry.grid(row=2, column=1)

tk.Button(root, text="Add", command=add_item).grid(row=0, column=2)
tk.Button(root, text="Update", command=update_item).grid(row=1, column=2)
tk.Button(root, text="Delete", command=delete_item).grid(row=2, column=2)
tk.Button(root, text="View All", command=view_items).grid(row=3, column=2)

listbox = tk.Listbox(root, width=50)
listbox.grid(row=4, column=0, columnspan=3)
listbox.bind('<<ListboxSelect>>', on_select)

view_items()

root.mainloop()

